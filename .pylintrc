[MAIN]
load-plugins =
    pylint_per_file_ignores

[TYPECHECK]
# pygsl_lite is an optional demo backend (C extension requiring system GSL); it
# is not installed in CI, so tell pylint not to try resolving it. scipy and
# matplotlib are installed in the lint job, so they are checked normally.
ignored-modules =
    pygsl_lite

[FORMAT]
max-module-lines=2000

[MESSAGES CONTROL]
per-file-ignores =
  tests/*:missing-function-docstring

# line length etc better handled by ruff
disable = line-too-long, too-many-locals, too-many-branches, too-many-statements, too-many-arguments, too-few-public-methods, too-many-positional-arguments
